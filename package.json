{
  "name": "aula-base-v3",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "pnpm --filter backend test",
    "db:generate": "pnpm --filter @aula/database generate",
    "db:migrate": "pnpm --filter @aula/database migrate",
    "db:seed": "pnpm --filter @aula/database seed",
    "db:studio": "pnpm --filter @aula/database studio",
    "cloudflare:dev": "node scripts/cloudflare-local.mjs",
    "cloudflare:build": "pnpm build && wrangler deploy --dry-run --env=\"\"",
    "cloudflare:deploy:production": "pnpm build && wrangler deploy --env=\"\"",
    "cloudflare:smoke": "node scripts/cloudflare-smoke.mjs",
    "cloudflare:verify": "node scripts/cloudflare-integration.mjs",
    "cloudflare:types": "wrangler types",
    "supabase:local": "supabase start -x edge-runtime,logflare,vector",
    "supabase:stop": "supabase stop",
    "supabase:keepalive": "node scripts/supabase-keepalive.mjs"
  },
  "devDependencies": {
    "prettier": "^3.2.0",
    "supabase": "^2.104.0",
    "turbo": "^2.5.0",
    "wrangler": "^4.111.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd",
      "@prisma/client",
      "@prisma/engines",
      "prisma"
    ]
  },
  "packageManager": "pnpm@11.1.2"
}
