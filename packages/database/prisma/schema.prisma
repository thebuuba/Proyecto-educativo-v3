generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RecordStatus {
  ACTIVE   @map("active")
  INACTIVE @map("inactive")
  ARCHIVED @map("archived")

  @@map("record_status")
}

enum EnrollmentStatus {
  ACTIVE      @map("active")
  TRANSFERRED @map("transferred")
  WITHDRAWN   @map("withdrawn")
  COMPLETED   @map("completed")

  @@map("enrollment_status")
}

enum AttendanceStatus {
  PRESENT @map("present")
  ABSENT  @map("absent")
  LATE    @map("late")
  EXCUSED @map("excused")

  @@map("attendance_status")
}

enum GradeRecordStatus {
  DRAFT     @map("draft")
  PUBLISHED @map("published")
  VOIDED    @map("voided")

  @@map("grade_record_status")
}

enum ReportStatus {
  PENDING   @map("pending")
  GENERATED @map("generated")
  FAILED    @map("failed")
  ARCHIVED  @map("archived")

  @@map("report_status")
}

model School {
  id                     String       @id @default(uuid()) @db.Uuid
  name                   String
  slug                   String       @unique
  logoUrl                String?      @map("logo_url")
  sector                 String       @default("private")
  centerCode             String?      @map("center_code")
  district               String?      @map("district")
  lat                    Float?       @map("lat")
  lng                    Float?       @map("lng")
  niveles                String[]     @default([])
  tandas                 String[]     @default([])
  modalidades            String[]     @default([])
  schoolShift            String       @default("extended") @map("school_shift")
  primaryModality        String       @default("general") @map("primary_modality")
  enabledSubsystems      String[]     @default(["regular"]) @map("enabled_subsystems")
  officialExportsEnabled Boolean      @default(true) @map("official_exports_enabled")
  status                 RecordStatus @default(ACTIVE)
  createdAt              DateTime     @default(now()) @map("created_at")
  updatedAt              DateTime     @updatedAt @map("updated_at")

  appUsers              AppUser[]
  schoolYears           SchoolYear[]
  academicPeriods       AcademicPeriod[]
  grades                Grade[]
  sections              Section[]
  subjects              Subject[]
  teachers              Teacher[]
  students              Student[]
  guardians             Guardian[]
  studentGuardians      StudentGuardian[]
  guardianNotifications GuardianNotification[]
  sectionSubjects       SectionSubject[]
  enrollments           Enrollment[]
  attendanceDailies     AttendanceDaily[]
  attendanceClasses     AttendanceClass[]
  gradesRecords         GradesRecord[]
  evaluationActivities  EvaluationActivity[]
  evaluationInstruments EvaluationInstrument[]
  activityEvidences     EvaluationActivityEvidence[]
  activityGroups        EvaluationActivityGroup[]
  activityGroupMembers  EvaluationActivityGroupMember[]
  courseTeams           CourseTeam[]
  courseTeamMembers     CourseTeamMember[]
  pedagogicalRecoveries PedagogicalRecovery[]
  reports               Report[]
  timeSlots             TimeSlot[]
  scheduleEntries       ScheduleEntry[]
  planningEntries       PlanningEntry[]
  dashboardTasks        DashboardTask[]
  userRoles             UserRole[]
  drEvaluationRules     DrEvaluationRule[]

  @@index([name])
  @@index([district])
  @@map("schools")
}

model Role {
  id          String       @id @default(uuid()) @db.Uuid
  key         String       @unique
  name        String       @unique
  description String?
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id          String       @id @default(uuid()) @db.Uuid
  key         String       @unique
  name        String
  description String?
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String       @map("role_id") @db.Uuid
  permissionId String       @map("permission_id") @db.Uuid
  status       RecordStatus @default(ACTIVE)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model AppUser {
  id           String       @id @default(uuid()) @db.Uuid
  authUserId   String       @unique @map("auth_user_id") @db.Uuid
  fullName     String       @map("full_name")
  email        String       @unique
  phone        String?
  avatarUrl    String?      @map("avatar_url")
  provider     String       @default("email")
  tokenVersion Int          @default(1) @map("token_version")
  lastLoginAt  DateTime?    @map("last_login_at")
  status       RecordStatus @default(ACTIVE)
  schoolId     String       @map("school_id") @db.Uuid
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  school                        School                 @relation(fields: [schoolId], references: [id])
  userRoles                     UserRole[]
  teacher                       Teacher?
  student                       Student?
  guardian                      Guardian?
  createdNotifications          GuardianNotification[]
  recordedAttendanceDailies     AttendanceDaily[]
  recordedAttendanceClasses     AttendanceClass[]
  recordedGradesRecords         GradesRecord[]
  createdEvaluationActivities   EvaluationActivity[]
  createdCourseTeams            CourseTeam[]
  recordedPedagogicalRecoveries PedagogicalRecovery[]
  generatedReports              Report[]
  assignedDashboardTasks        DashboardTask[]        @relation("DashboardAssignee")
  createdDashboardTasks         DashboardTask[]        @relation("DashboardCreator")

  @@map("app_users")
}

model UserRole {
  userId    String       @map("user_id") @db.Uuid
  roleId    String       @map("role_id") @db.Uuid
  status    RecordStatus @default(ACTIVE)
  schoolId  String       @map("school_id") @db.Uuid
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  user   AppUser @relation(fields: [userId], references: [id])
  role   Role    @relation(fields: [roleId], references: [id])
  school School  @relation(fields: [schoolId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model SchoolYear {
  id                String       @id @default(uuid()) @db.Uuid
  schoolId          String       @map("school_id") @db.Uuid
  name              String
  startDate         DateTime     @map("start_date") @db.Date
  endDate           DateTime     @map("end_date") @db.Date
  isCurrent         Boolean      @default(false) @map("is_current")
  periodScheme      String       @default("trimester") @map("period_scheme")
  periodCount       Int          @default(3) @map("period_count")
  calendarSource    String       @default("school") @map("calendar_source")
  instructionalDays Int?         @map("instructional_days")
  studentWeeks      Int?         @map("student_weeks")
  teacherWeeks      Int?         @map("teacher_weeks")
  status            RecordStatus @default(ACTIVE)
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  school               School               @relation(fields: [schoolId], references: [id])
  academicPeriods      AcademicPeriod[]
  enrollments          Enrollment[]
  sectionSubjects      SectionSubject[]
  attendanceDailies    AttendanceDaily[]
  attendanceClasses    AttendanceClass[]
  gradesRecords        GradesRecord[]
  evaluationActivities EvaluationActivity[]
  courseTeams          CourseTeam[]
  reports              Report[]
  scheduleEntries      ScheduleEntry[]

  @@unique([schoolId, name])
  @@index([schoolId, isCurrent])
  @@map("school_years")
}

model AcademicPeriod {
  id           String       @id @default(uuid()) @db.Uuid
  schoolYearId String       @map("school_year_id") @db.Uuid
  schoolId     String       @map("school_id") @db.Uuid
  name         String
  sequence     Int
  startDate    DateTime     @map("start_date") @db.Date
  endDate      DateTime     @map("end_date") @db.Date
  status       RecordStatus @default(ACTIVE)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  schoolYear           SchoolYear           @relation(fields: [schoolYearId], references: [id])
  school               School               @relation(fields: [schoolId], references: [id])
  attendanceDailies    AttendanceDaily[]
  attendanceClasses    AttendanceClass[]
  gradesRecords        GradesRecord[]
  evaluationActivities EvaluationActivity[]
  scheduleEntries      ScheduleEntry[]
  planningEntries      PlanningEntry[]
  reports              Report[]

  @@unique([schoolYearId, sequence])
  @@unique([schoolYearId, name])
  @@unique([id, schoolYearId])
  @@map("academic_periods")
}

model Grade {
  id                String       @id @default(uuid()) @db.Uuid
  schoolId          String       @map("school_id") @db.Uuid
  name              String
  level             String?
  sequence          Int?
  academicLevelId   String?      @map("academic_level_id") @db.Uuid
  academicCycleId   String?      @map("academic_cycle_id") @db.Uuid
  defaultModalityId String?      @map("default_modality_id") @db.Uuid
  status            RecordStatus @default(ACTIVE)
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  school          School           @relation(fields: [schoolId], references: [id])
  academicLevel   DrAcademicLevel? @relation(fields: [academicLevelId], references: [id])
  academicCycle   DrAcademicCycle? @relation(fields: [academicCycleId], references: [id])
  defaultModality DrModality?      @relation(fields: [defaultModalityId], references: [id])
  sections        Section[]
  sectionSubjects SectionSubject[]
  enrollments     Enrollment[]

  @@unique([schoolId, name, academicLevelId, academicCycleId])
  @@index([schoolId, status])
  @@map("grades")
}

model Section {
  id        String       @id @default(uuid()) @db.Uuid
  gradeId   String       @map("grade_id") @db.Uuid
  schoolId  String       @map("school_id") @db.Uuid
  name      String
  capacity  Int?
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  grade             Grade             @relation(fields: [gradeId], references: [id])
  school            School            @relation(fields: [schoolId], references: [id])
  sectionSubjects   SectionSubject[]
  enrollments       Enrollment[]
  attendanceDailies AttendanceDaily[]
  attendanceClasses AttendanceClass[]
  scheduleEntries   ScheduleEntry[]
  gradesRecords     GradesRecord[]
  courseTeams       CourseTeam[]

  @@unique([gradeId, name])
  @@unique([id, gradeId])
  @@index([schoolId, status])
  @@map("sections")
}

model Subject {
  id          String       @id @default(uuid()) @db.Uuid
  code        String
  schoolId    String       @map("school_id") @db.Uuid
  name        String
  description String?
  credits     Decimal?     @db.Decimal(5, 2)
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  school          School           @relation(fields: [schoolId], references: [id])
  sectionSubjects SectionSubject[]

  @@unique([schoolId, code])
  @@index([schoolId, status])
  @@map("subjects")
}

model Teacher {
  id           String       @id @default(uuid()) @db.Uuid
  userId       String?      @unique @map("user_id") @db.Uuid
  schoolId     String       @map("school_id") @db.Uuid
  employeeCode String       @map("employee_code")
  firstName    String       @map("first_name")
  lastName     String       @map("last_name")
  documentId   String?      @map("document_id")
  birthDate    DateTime?    @map("birth_date") @db.Date
  gender       String?
  phone        String?
  email        String?
  hireDate     DateTime?    @map("hire_date") @db.Date
  address      String?
  status       RecordStatus @default(ACTIVE)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  user            AppUser?         @relation(fields: [userId], references: [id])
  school          School           @relation(fields: [schoolId], references: [id])
  sectionSubjects SectionSubject[]

  @@unique([schoolId, employeeCode])
  @@unique([schoolId, documentId])
  @@unique([schoolId, email])
  @@index([schoolId, status])
  @@map("teachers")
}

model Student {
  id          String       @id @default(uuid()) @db.Uuid
  userId      String?      @unique @map("user_id") @db.Uuid
  schoolId    String       @map("school_id") @db.Uuid
  studentCode String       @map("student_code")
  firstName   String       @map("first_name")
  lastName    String       @map("last_name")
  documentId  String?      @map("document_id")
  birthDate   DateTime     @map("birth_date") @db.Date
  gender      String?
  address     String?
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  user                  AppUser?               @relation(fields: [userId], references: [id])
  school                School                 @relation(fields: [schoolId], references: [id])
  enrollments           Enrollment[]
  guardianNotifications GuardianNotification[]
  studentGuardians      StudentGuardian[]
  reports               Report[]

  @@unique([schoolId, studentCode])
  @@unique([schoolId, documentId])
  @@map("students")
}

model Guardian {
  id         String       @id @default(uuid()) @db.Uuid
  userId     String?      @unique @map("user_id") @db.Uuid
  schoolId   String       @map("school_id") @db.Uuid
  fullName   String       @map("full_name")
  documentId String?      @map("document_id")
  phone      String?
  email      String?
  address    String?
  status     RecordStatus @default(ACTIVE)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  user                  AppUser?               @relation(fields: [userId], references: [id])
  school                School                 @relation(fields: [schoolId], references: [id])
  studentGuardians      StudentGuardian[]
  guardianNotifications GuardianNotification[]

  @@unique([schoolId, documentId])
  @@map("guardians")
}

model StudentGuardian {
  studentId    String       @map("student_id") @db.Uuid
  guardianId   String       @map("guardian_id") @db.Uuid
  schoolId     String       @map("school_id") @db.Uuid
  relationship String
  isPrimary    Boolean      @default(false) @map("is_primary")
  canPickUp    Boolean      @default(false) @map("can_pick_up")
  status       RecordStatus @default(ACTIVE)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  student  Student  @relation(fields: [studentId], references: [id])
  guardian Guardian @relation(fields: [guardianId], references: [id])
  school   School   @relation(fields: [schoolId], references: [id])

  @@id([studentId, guardianId])
  @@map("student_guardians")
}

model GuardianNotification {
  id         String   @id @default(uuid()) @db.Uuid
  schoolId   String   @map("school_id") @db.Uuid
  studentId  String   @map("student_id") @db.Uuid
  guardianId String?  @map("guardian_id") @db.Uuid
  createdBy  String   @map("created_by") @db.Uuid
  channel    String   @default("manual")
  subject    String
  message    String
  status     String   @default("draft")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  school   School    @relation(fields: [schoolId], references: [id])
  student  Student   @relation(fields: [studentId], references: [id])
  guardian Guardian? @relation(fields: [guardianId], references: [id])
  creator  AppUser   @relation(fields: [createdBy], references: [id])

  @@index([schoolId])
  @@index([studentId])
  @@index([createdAt])
  @@index([status])
  @@map("guardian_notifications")
}

model SectionSubject {
  id           String       @id @default(uuid()) @db.Uuid
  schoolYearId String       @map("school_year_id") @db.Uuid
  schoolId     String       @map("school_id") @db.Uuid
  gradeId      String       @map("grade_id") @db.Uuid
  sectionId    String       @map("section_id") @db.Uuid
  subjectId    String       @map("subject_id") @db.Uuid
  teacherId    String?      @map("teacher_id") @db.Uuid
  appearanceColor String?   @map("appearance_color")
  appearanceIcon  String?   @map("appearance_icon")
  status       RecordStatus @default(ACTIVE)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  schoolYear           SchoolYear           @relation(fields: [schoolYearId], references: [id])
  school               School               @relation(fields: [schoolId], references: [id])
  grade                Grade                @relation(fields: [gradeId], references: [id])
  section              Section              @relation(fields: [sectionId], references: [id])
  subject              Subject              @relation(fields: [subjectId], references: [id])
  teacher              Teacher?             @relation(fields: [teacherId], references: [id])
  attendanceClasses    AttendanceClass[]
  gradesRecords        GradesRecord[]
  evaluationActivities EvaluationActivity[]
  courseTeams          CourseTeam[]
  scheduleEntries      ScheduleEntry[]
  planningEntries      PlanningEntry[]

  @@unique([schoolYearId, sectionId, subjectId])
  @@unique([id, schoolYearId, sectionId])
  @@index([schoolId, status])
  @@index([schoolId, sectionId])
  @@map("section_subjects")
}

model Enrollment {
  id              String           @id @default(uuid()) @db.Uuid
  studentId       String           @map("student_id") @db.Uuid
  schoolYearId    String           @map("school_year_id") @db.Uuid
  schoolId        String           @map("school_id") @db.Uuid
  gradeId         String           @map("grade_id") @db.Uuid
  sectionId       String           @map("section_id") @db.Uuid
  enrollmentDate  DateTime         @default(now()) @map("enrollment_date") @db.Date
  academicLevelId String?          @map("academic_level_id") @db.Uuid
  academicCycleId String?          @map("academic_cycle_id") @db.Uuid
  modalityId      String?          @map("modality_id") @db.Uuid
  subsystemId     String?          @map("subsystem_id") @db.Uuid
  academicStatus  String           @default("active") @map("academic_status")
  isRepeating     Boolean          @default(false) @map("is_repeating")
  promotionStatus String?          @map("promotion_status")
  finalCondition  String?          @map("final_condition")
  transferNotes   String?          @map("transfer_notes")
  status          EnrollmentStatus @default(ACTIVE)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  student                        Student                         @relation(fields: [studentId], references: [id])
  schoolYear                     SchoolYear                      @relation(fields: [schoolYearId], references: [id])
  school                         School                          @relation(fields: [schoolId], references: [id])
  grade                          Grade                           @relation(fields: [gradeId], references: [id])
  section                        Section                         @relation(fields: [sectionId], references: [id])
  academicLevel                  DrAcademicLevel?                @relation(fields: [academicLevelId], references: [id])
  academicCycle                  DrAcademicCycle?                @relation(fields: [academicCycleId], references: [id])
  modality                       DrModality?                     @relation(fields: [modalityId], references: [id])
  subsystem                      DrSubsystem?                    @relation(fields: [subsystemId], references: [id])
  attendanceDailies              AttendanceDaily[]
  attendanceClasses              AttendanceClass[]
  gradesRecords                  GradesRecord[]
  evaluationActivityGroupMembers EvaluationActivityGroupMember[]
  courseTeamMembers              CourseTeamMember[]

  @@unique([studentId, schoolYearId])
  @@unique([id, schoolYearId, sectionId])
  @@index([schoolId, status])
  @@index([schoolId, sectionId, schoolYearId, status])
  @@map("enrollments")
}

model AttendanceDaily {
  id               String           @id @default(uuid()) @db.Uuid
  enrollmentId     String           @map("enrollment_id") @db.Uuid
  schoolYearId     String           @map("school_year_id") @db.Uuid
  sectionId        String           @map("section_id") @db.Uuid
  schoolId         String           @map("school_id") @db.Uuid
  academicPeriodId String           @map("academic_period_id") @db.Uuid
  attendanceDate   DateTime         @map("attendance_date") @db.Date
  status           AttendanceStatus
  notes            String?
  recordedBy       String?          @map("recorded_by") @db.Uuid
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  enrollment     Enrollment     @relation(fields: [enrollmentId], references: [id])
  schoolYear     SchoolYear     @relation(fields: [schoolYearId], references: [id])
  section        Section        @relation(fields: [sectionId], references: [id])
  school         School         @relation(fields: [schoolId], references: [id])
  academicPeriod AcademicPeriod @relation(fields: [academicPeriodId], references: [id])
  recorder       AppUser?       @relation(fields: [recordedBy], references: [id])

  @@unique([enrollmentId, attendanceDate])
  @@map("attendance_daily")
}

model AttendanceClass {
  id               String           @id @default(uuid()) @db.Uuid
  enrollmentId     String           @map("enrollment_id") @db.Uuid
  schoolYearId     String           @map("school_year_id") @db.Uuid
  sectionId        String           @map("section_id") @db.Uuid
  schoolId         String           @map("school_id") @db.Uuid
  sectionSubjectId String           @map("section_subject_id") @db.Uuid
  academicPeriodId String           @map("academic_period_id") @db.Uuid
  attendanceDate   DateTime         @map("attendance_date") @db.Date
  status           AttendanceStatus
  notes            String?
  recordedBy       String?          @map("recorded_by") @db.Uuid
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  enrollment     Enrollment     @relation(fields: [enrollmentId], references: [id])
  schoolYear     SchoolYear     @relation(fields: [schoolYearId], references: [id])
  section        Section        @relation(fields: [sectionId], references: [id])
  school         School         @relation(fields: [schoolId], references: [id])
  sectionSubject SectionSubject @relation(fields: [sectionSubjectId], references: [id])
  academicPeriod AcademicPeriod @relation(fields: [academicPeriodId], references: [id])
  recorder       AppUser?       @relation(fields: [recordedBy], references: [id])

  @@unique([enrollmentId, sectionSubjectId, attendanceDate])
  @@map("attendance_class")
}

model GradesRecord {
  id                   String            @id @default(uuid()) @db.Uuid
  enrollmentId         String            @map("enrollment_id") @db.Uuid
  schoolYearId         String            @map("school_year_id") @db.Uuid
  sectionId            String            @map("section_id") @db.Uuid
  schoolId             String            @map("school_id") @db.Uuid
  sectionSubjectId     String            @map("section_subject_id") @db.Uuid
  academicPeriodId     String            @map("academic_period_id") @db.Uuid
  evaluationActivityId String?           @map("evaluation_activity_id") @db.Uuid
  assessmentName       String            @map("assessment_name")
  score                Decimal           @db.Decimal(8, 2)
  maxScore             Decimal           @default(100) @map("max_score") @db.Decimal(8, 2)
  weight               Decimal           @default(1) @db.Decimal(8, 4)
  status               GradeRecordStatus @default(DRAFT)
  recordedBy           String?           @map("recorded_by") @db.Uuid
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")

  enrollment          Enrollment           @relation(fields: [enrollmentId], references: [id])
  schoolYear          SchoolYear           @relation(fields: [schoolYearId], references: [id])
  section             Section              @relation(fields: [sectionId], references: [id])
  school              School               @relation(fields: [schoolId], references: [id])
  sectionSubject      SectionSubject       @relation(fields: [sectionSubjectId], references: [id])
  academicPeriod      AcademicPeriod       @relation(fields: [academicPeriodId], references: [id])
  evaluationActivity  EvaluationActivity?  @relation(fields: [evaluationActivityId], references: [id])
  recorder            AppUser?             @relation(fields: [recordedBy], references: [id])
  pedagogicalRecovery PedagogicalRecovery?

  @@index([schoolId, sectionSubjectId, academicPeriodId])
  @@index([evaluationActivityId])
  @@index([enrollmentId, academicPeriodId])
  @@map("grades_records")
}

model EvaluationActivity {
  id                   String       @id @default(uuid()) @db.Uuid
  schoolId             String       @map("school_id") @db.Uuid
  schoolYearId         String       @map("school_year_id") @db.Uuid
  sectionSubjectId     String       @map("section_subject_id") @db.Uuid
  academicPeriodId     String       @map("academic_period_id") @db.Uuid
  planningEntryId      String?      @map("planning_entry_id") @db.Uuid
  instrumentId         String?      @map("instrument_id") @db.Uuid
  competencyBlockId    String       @map("competency_block_id")
  planningMoment       String?      @map("planning_moment")
  name                 String
  description          String       @default("")
  activityType         String       @default("individual") @map("activity_type")
  maxScore             Decimal      @default(100) @map("max_score") @db.Decimal(8, 2)
  activityDate         DateTime?    @map("activity_date") @db.Date
  evaluationTechnique  String       @default("") @map("evaluation_technique")
  studentRole          String       @default("") @map("student_role")
  teacherRole          String       @default("") @map("teacher_role")
  evidenceInstructions String       @default("") @map("evidence_instructions")
  observations         String       @default("")
  resources            String[]     @default([])
  source               String       @default("grading")
  status               RecordStatus @default(ACTIVE)
  createdBy            String?      @map("created_by") @db.Uuid
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  school         School                       @relation(fields: [schoolId], references: [id])
  schoolYear     SchoolYear                   @relation(fields: [schoolYearId], references: [id])
  sectionSubject SectionSubject               @relation(fields: [sectionSubjectId], references: [id])
  academicPeriod AcademicPeriod               @relation(fields: [academicPeriodId], references: [id])
  planningEntry  PlanningEntry?               @relation(fields: [planningEntryId], references: [id])
  instrument     EvaluationInstrument?        @relation(fields: [instrumentId], references: [id])
  creator        AppUser?                     @relation(fields: [createdBy], references: [id])
