{
  "name": "@aula/database",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "generate": "dotenv -e ../../apps/backend/.env -- prisma generate",
    "migrate": "dotenv -e ../../apps/backend/.env -- prisma migrate dev",
    "seed": "dotenv -e ../../apps/backend/.env -- tsx src/seed.ts",
    "seed:schools": "dotenv -e ../../apps/backend/.env -- tsx src/seed-schools.ts",
    "seed:school-defaults": "dotenv -e ../../apps/backend/.env -- tsx src/seed-school-defaults.ts",
    "seed:schools-missing": "dotenv -e ../../apps/backend/.env -- tsx src/seed-schools-missing.ts",
    "seed:school-coords": "dotenv -e ../../apps/backend/.env -- tsx src/seed-school-coords.ts",
    "studio": "dotenv -e ../../apps/backend/.env -- prisma studio",
    "build": "tsc"
  },
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "dependencies": {
    "@prisma/adapter-pg": "6.19.3",
    "@prisma/client": "^6.5.0",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "@types/pg": "^8.20.0",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.5.0",
    "tsx": "^4.19.0",
    "typescript": "~6.0.2"
  }
}
