PORT=3000
# Direct connection (fewer connections, ~15-60 max). Usar solo para migrations.
# DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres
# Pooled connection (hasta ~200 conexiones). Usar para el servidor en producción.
DATABASE_URL=postgresql://postgres.xxxxx:password@aws-0-us-west-1.pooler.supabase.com:6543/postgres
JWT_SECRET=change-me-to-a-random-secret
FRONTEND_URL=http://localhost:5173
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-server-only-secret-key
SUPABASE_ANON_KEY=replace-with-public-anon-key
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-5.5
