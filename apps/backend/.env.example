PORT=3000
# Conexión local a Supabase. En Cloudflare se usa el binding HYPERDRIVE.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@POOLER_HOST:6543/postgres
# Para migraciones locales, puedes reemplazar DATABASE_URL por direct connection si tu red lo soporta:
# postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
JWT_SECRET=change-me-to-a-random-secret
FRONTEND_URL=http://localhost:5173
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-server-only-secret-key
SUPABASE_ANON_KEY=replace-with-public-anon-key
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-5.5
SEED_ADMIN_EMAIL=admin@test.com
SEED_ADMIN_PASSWORD=replace-with-local-admin-password
